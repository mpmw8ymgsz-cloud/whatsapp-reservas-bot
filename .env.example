PORT=3000

# Token de acceso de Meta (System User token permanente, ver README)
META_TOKEN=tu_token_de_acceso_de_meta

# ID del número de WhatsApp (Phone Number ID), lo ves en Meta for Developers > WhatsApp > API Setup
PHONE_NUMBER_ID=tu_phone_number_id

# Token secreto que TU inventas, para verificar el webhook con Meta
VERIFY_TOKEN=un_token_secreto_que_tu_inventes

# Número de WhatsApp del dueño/administrador para recibir notificaciones de nuevas reservas
# Formato internacional sin '+' ni espacios, ej: 34600000000
ADMIN_PHONE=

# Credenciales de tu base de datos en Turso (turso.tech), ver README
TURSO_DATABASE_URL=libsql://tu-base-de-datos.turso.io
TURSO_AUTH_TOKEN=tu_token_de_turso
